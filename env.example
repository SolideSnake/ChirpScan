# ChirpScan 2.0 环境变量示例

# X 采集
TWITTER_PROVIDER=twikit
TWITTER_POLL_INTERVAL_SEC=300
TWITTER_FETCH_LIMIT=5
TWITTER_BOOTSTRAP_DROP_EXISTING=true

# 统一监控目标：每个目标可分别开启电报、飞书和币安广场
MONITOR_TARGETS=[{"username":"elonmusk","enabled":true,"include_replies":false,"platforms":{"telegram":{"enabled":true,"include_keywords":"","exclude_keywords":""},"feishu":{"enabled":false,"include_keywords":"","exclude_keywords":""},"binance_square":{"enabled":false,"include_keywords":"","exclude_keywords":""}}}]

# Twikit 登录信息
# 优先使用 Cookies 文件；用户名、邮箱、密码只作为缺少 Cookies 时的备用登录方式。
TWIKIT_COOKIES_FILE=.twikit_cookies.json
TWIKIT_USERNAME=
TWIKIT_EMAIL=
TWIKIT_PASSWORD=

# 电报推送
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 飞书 Webhook 推送
# 如果飞书自定义机器人开启签名校验，请同时填写 FEISHU_SECRET。
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# 通知通道重试（电报、飞书共用）
RETRY_MAX_ATTEMPTS=4
RETRY_BASE_DELAY_SEC=1.5

# 币安广场发布
# 全局默认可用，实际是否发布由 MONITOR_TARGETS 中每个目标的 binance_square.enabled 决定。
# 币安广场只发送清理后的纯正文，不追加原推链接，也会移除正文中的 URL。
BINANCE_SQUARE_API_KEY=
BINANCE_RETRY_MAX_ATTEMPTS=3
BINANCE_RETRY_BASE_DELAY_SEC=2.0

# 本地状态文件
DEDUP_FILE=.state/dedup.json
DEDUP_MAX_IDS=5000
DELIVERY_STATUS_FILE=.state/delivery_status.json
DELIVERY_STATUS_MAX_RECORDS=5000

# 日志
LOG_LEVEL=INFO
