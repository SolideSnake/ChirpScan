# Provider: twikit | mock
TWITTER_PROVIDER=mock
MONITOR_TARGETS=[{"username":"elonmusk","enabled":true}]
TWITTER_POLL_INTERVAL_SEC=60
TWITTER_FETCH_LIMIT=5
TWITTER_BOOTSTRAP_DROP_EXISTING=true

# Twikit credentials (required when TWITTER_PROVIDER=twikit)
TWIKIT_USERNAME=
TWIKIT_EMAIL=
TWIKIT_PASSWORD=
TWIKIT_COOKIES_FILE=.twikit_cookies.json

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DEDUP_FILE=.state/dedup.json
DEDUP_MAX_IDS=5000

RETRY_MAX_ATTEMPTS=4
RETRY_BASE_DELAY_SEC=1.5

LOG_LEVEL=INFO
DRY_RUN=true

